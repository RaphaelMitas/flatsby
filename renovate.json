{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":separateMajorReleases",
    ":combinePatchMinorReleases",
    "group:expoMonorepo"
  ],
  "baseBranchPatterns": ["develop"],
  "rangeStrategy": "bump",
  "labels": ["dependencies"],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on the first day of the month"]
  },
  "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Expo-managed deps – update via `expo doctor --fix-dependencies`, not Renovate",
      "matchFileNames": ["apps/expo/package.json"],
      "matchPackageNames": [
        "/^expo/",
        "react-native",
        "react-native-gesture-handler",
        "react-native-reanimated",
        "react-native-safe-area-context",
        "react-native-screens",
        "react-native-worklets",
        "react-native-css",
        "@react-native-async-storage/async-storage",
        "@react-native-community/datetimepicker"
      ],
      "enabled": false
    },
    {
      "description": "React pinned to Expo SDK-compatible version – update when upgrading Expo SDK",
      "matchPackageNames": [
        "react",
        "react-dom",
        "@types/react",
        "@types/react-dom"
      ],
      "enabled": false
    },
    {
      "description": "Group Next.js",
      "groupName": "nextjs",
      "matchPackageNames": ["next", "eslint-config-next", "@next/env"]
    },
    {
      "description": "Group tRPC",
      "groupName": "trpc",
      "matchPackageNames": ["/^@trpc//"]
    },
    {
      "description": "Group Drizzle",
      "groupName": "drizzle",
      "matchPackageNames": ["/^drizzle-/"]
    },
    {
      "description": "Group Tailwind CSS",
      "groupName": "tailwindcss",
      "matchPackageNames": ["/^@tailwindcss//", "/^tailwindcss$/"]
    },
    {
      "description": "Group Radix UI",
      "groupName": "radix-ui",
      "automerge": true,
      "matchPackageNames": ["/^@radix-ui//"]
    },
    {
      "description": "Group AI SDK",
      "groupName": "ai-sdk",
      "matchPackageNames": ["/^@ai-sdk//", "/^ai$/"]
    },
    {
      "description": "Group Tanstack",
      "groupName": "tanstack",
      "matchPackageNames": ["/^@tanstack//"]
    },
    {
      "description": "Group ESLint",
      "groupName": "eslint",
      "matchPackageNames": [
        "/^eslint/",
        "/^@eslint//",
        "/^@typescript-eslint//"
      ]
    },
    {
      "description": "Group PostHog",
      "groupName": "posthog",
      "matchPackageNames": ["/^posthog/", "/^@posthog//"]
    },
    {
      "description": "Group type definitions",
      "groupName": "types",
      "automerge": true,
      "matchPackageNames": ["/^@types//"]
    },
    {
      "description": "Allow Better Auth prereleases",
      "matchPackageNames": ["better-auth"],
      "ignoreUnstable": false
    }
  ]
}
