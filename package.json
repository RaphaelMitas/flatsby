{
  "name": "flatsby",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.18.0",
    "pnpm": "^10.34.4"
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af",
  "scripts": {
    "build": "turbo run build",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "db:generate": "turbo -F @flatsby/db generate",
    "db:migrate": "turbo -F @flatsby/db migrate",
    "db:push": "turbo -F @flatsby/db push",
    "db:studio": "turbo -F @flatsby/db studio",
    "dev": "bash scripts/setup-adb-reverse.sh; turbo watch dev --continue",
    "dev:next": "turbo watch dev -F @flatsby/nextjs...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "pnpm dlx shadcn@latest add -c packages/ui"
  },
  "devDependencies": {
    "@flatsby/prettier-config": "workspace:*",
    "prettier": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@flatsby/prettier-config"
}
