{
  "name": "@flatsby/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./hooks/useShoppingListSuggestions": {
      "types": "./dist/hooks/useShoppingListSuggestions.d.ts",
      "default": "./src/hooks/useShoppingListSuggestions.ts"
    }
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@flatsby/auth": "workspace:*",
    "@flatsby/db": "workspace:*",
    "@flatsby/validators": "workspace:*",
    "@posthog/ai": "7.14.0",
    "@trpc/server": "catalog:",
    "ai": "catalog:",
    "effect": "^3.21.1",
    "posthog-node": "^5.29.2",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flatsby/eslint-config": "workspace:*",
    "@flatsby/prettier-config": "workspace:*",
    "@flatsby/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-pacer": "*",
    "@tanstack/react-query": "catalog:",
    "react": "catalog:react19"
  },
  "prettier": "@flatsby/prettier-config"
}
