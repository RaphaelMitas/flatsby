{
  "extends": "@flatsby/tsconfig/internal-package.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom"],
    "types": ["react"],
    "jsx": "preserve",
    "rootDir": ".",
    "paths": {
      "@flatsby/ui": ["./src"],
      "@flatsby/ui/*": ["./src/*"],
      "@flatsby/ui/hooks": ["./hooks"],
      "@flatsby/ui/hooks/*": ["./hooks/*"]
    }
  },
  "include": ["src", "hooks"],
  "exclude": ["node_modules"]
}
