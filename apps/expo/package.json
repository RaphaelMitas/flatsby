{
  "name": "@flatsby/expo",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "clean": "git clean -xdf .cache .expo .turbo android ios node_modules",
    "clean:cache": "rm -rf node_modules/.cache",
    "dev": "expo start",
    "dev:clean": "pnpm clean:cache && expo start --clear",
    "dev:fresh": "rm -rf node_modules/.cache .expo && expo start --clear",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "eas:build": "cross-env EXPO_NO_CAPABILITY_SYNC=1 eas build --profile development",
    "eas:build:prod": "cross-env EXPO_NO_CAPABILITY_SYNC=1 eas build --profile production --auto-submit",
    "eas:build:local": "cross-env EXPO_NO_CAPABILITY_SYNC=1 eas build --profile development --local",
    "eas:update": "eas update --environment development",
    "eas:update:prod": "eas update --environment production",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path .prettierignore",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test:e2e": "maestro test e2e/flows/"
  },
  "dependencies": {
    "@ai-sdk/react": "catalog:",
    "@babel/traverse--for-generate-function-map": "npm:@babel/traverse@^7.29.0",
    "@better-auth/expo": "catalog:better-auth",
    "@bottom-tabs/react-navigation": "^1.1.0",
    "@expo/metro-runtime": "~55.0.9",
    "@flatsby/chat": "workspace:*",
    "@flatsby/validators": "workspace:*",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^8.6.0",
    "@react-native-vector-icons/get-image": "^13.0.0",
    "@react-native-vector-icons/lucide": "^13.0.0",
    "@shopify/flash-list": "^2.3.1",
    "@stardazed/streams-text-encoding": "^1.0.2",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "better-auth": "catalog:better-auth",
    "expo": "~55.0.11",
    "expo-application": "~55.0.12",
    "expo-build-properties": "~55.0.11",
    "expo-constants": "~55.0.11",
    "expo-dev-client": "~55.0.22",
    "expo-device": "~55.0.12",
    "expo-document-picker": "^55.0.11",
    "expo-file-system": "~55.0.14",
