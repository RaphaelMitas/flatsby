    "@flatsby/prettier-config": "workspace:*",
    "@flatsby/tailwind-config": "workspace:*",
    "@flatsby/tsconfig": "workspace:*",
    "@types/react": "catalog:react19",
    "cross-env": "^10.1.0",
    "eslint": "catalog:",
