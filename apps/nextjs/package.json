{
  "name": "@flatsby/nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .cache .next .turbo node_modules",
    "dev": "pnpm with-env next dev",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start",
    "test:e2e": "pnpm with-env playwright test",
    "test:e2e:ui": "pnpm with-env playwright test --ui",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "@ai-sdk/react": "catalog:",
    "@better-auth/expo": "catalog:better-auth",
    "@flatsby/api": "workspace:*",
    "@flatsby/auth": "workspace:*",
    "@flatsby/chat": "workspace:*",
    "@flatsby/db": "workspace:*",
    "@flatsby/ui": "workspace:*",
    "@flatsby/validators": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "@tanstack/react-pacer": "^0.21.1",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "catalog:",
    "ai": "catalog:",
    "autumn-js": "catalog:",
    "better-auth": "catalog:better-auth",
    "geist": "^1.7.0",
    "jose": "^6.2.3",
    "next": "catalog:",
    "prop-types": "^15.8.1",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-intersection-observer": "^10.0.3",
    "react-swipeable-list": "^1.10.0",
    "superjson": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flatsby/eslint-config": "workspace:*",
    "@flatsby/prettier-config": "workspace:*",
    "@flatsby/tailwind-config": "workspace:*",
    "@flatsby/tsconfig": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "babel-plugin-react-compiler": "catalog:",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "jiti": "^2.6.1",
    "prettier": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:"
  },
  "prettier": "@flatsby/prettier-config"
}
