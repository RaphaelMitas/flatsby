{
  "extends": "@flatsby/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["ES2022", "dom"],
    "types": ["node", "react", "react-dom"],
    "jsx": "preserve",
    "paths": {
      "~/*": ["./src/*"]
    },
    "plugins": [{ "name": "next" }],
    "module": "esnext"
  },
  "include": [".", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
