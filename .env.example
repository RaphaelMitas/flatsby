# Environment variables example
# Copy this file to .env and fill in the values as needed

# Database
# Required by packages/db and apps/nextjs
DATABASE_URL=

# Next.js server
# Optional: port used in development fallback logic
PORT=3000

# Auth (packages/auth)
# IMPORTANT: For OAuth proxy to work on localhost, this must match the production value.
# The proxy encrypts/decrypts state between localhost and production using this secret.
BETTER_AUTH_SECRET=

# OAuth providers
# Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# Apple Sign In
APPLE_KEY_ID=
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=
APPLE_SERVICE_ID=

# AI Keys
AI_GATEWAY_API_KEY=

# Autmn
AUTUMN_SECRET_KEY=

# Production URL for OAuth proxy (e.g. https://app.flatsby.com)
# On localhost, set this to your production URL so the OAuth proxy can redirect through it.
# On Vercel, this should be your custom domain.
BETTER_AUTH_URL=

# Vercel (optional, used to construct production URLs)
# VERCEL_URL=
# VERCEL_PROJECT_PRODUCTION_URL=

# E2E Testing (optional, used to enable testUtils plugin)
E2E_TESTING=true