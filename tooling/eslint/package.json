{
  "name": "@flatsby/eslint-config",
  "private": true,
  "type": "module",
  "exports": {
    "./base": "./base.ts",
    "./nextjs": "./nextjs.ts",
    "./react": "./react.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "catalog:",
    "@next/eslint-plugin-next": "^16.2.9",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-turbo": "^2.10.0",
    "typescript-eslint": "^8.61.1"
  },
  "devDependencies": {
    "@flatsby/prettier-config": "workspace:*",
    "@flatsby/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@flatsby/prettier-config"
}
